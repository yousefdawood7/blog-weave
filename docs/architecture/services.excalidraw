      "link": null,
      "locked": false,
      "text": "GET   /posts  (return all posts)\nPOST  /posts  (submit a post)\n{ title: \"post-title\" }\nPOST  /event (Handling event from event bus)\n{\n    type: \"PostCreated\",\n    payload: {id: postID, title: \"new Post Title\"} \n}\n",
      "fontSize": 25.589234208282008,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "GET   /posts  (return all posts)\nPOST  /posts  (submit a post)\n{ title: \"post-title\" }\nPOST  /event (Handling event from event bus)\n{\n    type: \"PostCreated\",\n    payload: {id: postID, title: \"new Post Title\"} \n}\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
