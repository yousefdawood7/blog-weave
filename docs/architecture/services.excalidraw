      "text": "GET   /posts/:id/comments  (return all comments)\nPOST   /posts/:id/comments  (submit a comment)\n{ content: \"new comment\" }\nPOST  /event (Handling event from event bus)\n{\n    type: \"CommentCreated\",\n    payload: {id: commentID, content: \"new Comment Title\"} \n}\n\n",
      "fontSize": 23.032510561179734,
      "fontFamily": 5,
